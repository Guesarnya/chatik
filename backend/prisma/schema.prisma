model Dish {
  id          Int      @id @default(autoincrement())
  username    String
  telegram_id String
  date_act    DateTime
  dish_name   String
  calories    Int
  belki       Int
  zhiri       Int
  uglevodi    Int
  weight      Int
  path_image  String
}
